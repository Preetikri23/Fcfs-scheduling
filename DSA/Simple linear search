#include <stdio.h>

int main() {
    int n, i, sum = 0;

    printf("Enter number of elements (including missing one): ");
    scanf("%d", &n);

    int arr[n-1];

    printf("Enter %d elements:\n", n-1);
    for(i = 0; i < n-1; i++) {
        scanf("%d", &arr[i]);
        sum += arr[i];
    }

    int total = n * (n + 1) / 2;
    int missing = total - sum;

    printf("Missing number is: %d\n", missing);

    return 0;
}
