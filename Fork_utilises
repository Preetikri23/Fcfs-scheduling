#include <stdio.h>
#include <stdlib.h>
#include <unisid.h>
#include <sys/types.h>
#include <fcntl.h>
#include <string.h>
int main (){
int fd = open("output.txt", O_CREAT I O_WRONLY I O_APPEND, 0644);
    if (fd < 0) {
        perror("file open failed");
        exit(1);
    }
pid_t pid = fork();
if (pid < 0) {
    perror("Fork failed");
    exit(1);
    
}

//-------write child logic -------
if (pid == 0) {
    char child_msg[] = "This line is written by the child process.\n";
    write(fd, child_msg,
strlen(child_msg));
        close(fd);
        exit(0);
}

//-------write parent logic -------
else {
    wait(NULL);  //Parent waits for child to finish

    char parent_msg[] = "This line is written by the parent process.\n";
    write(fd, parent_msg,
strlen(parent_msg));
        close(fd);
}
return 0;
}
